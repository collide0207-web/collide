# Collide frontend environment. Copy to .env.local and adjust.

# Collab (Yjs sync) WebSocket base. roomId is appended by the provider.
VITE_COLLAB_URL=ws://localhost:4000/doc

# Control-plane REST base. If UNSET, the app uses the in-memory mock API (no backend
# needed). Set this to talk to the real Spring Boot auth service.
VITE_API_URL=http://localhost:8080

# Google OAuth2 client id for "Continue with Google". If unset, the Google button is
# hidden. Must match the control plane's GOOGLE_CLIENT_ID.
# VITE_GOOGLE_CLIENT_ID=1234567890-abcdef.apps.googleusercontent.com
